<!-- ============================================================
     navigation.launch — AMCL Localization + move_base Navigation
     Run this AFTER mapping.launch to enable autonomous navigation.
     
     Usage:
       roslaunch turtlebot3_delivery navigation.launch \
         map_file:=$HOME/maps/restaurant_map.yaml
     ============================================================ -->
<launch>
  <!-- ── Arguments ────────────────────────────────────────── -->
  <arg name="model"    default="waffle"/>
  <arg name="map_file" default="$(find turtlebot3_delivery)/../../../maps/restaurant_map.yaml"/>
  <arg name="open_rviz" default="true"/>

  <!-- ── Robot model ──────────────────────────────────────── -->
  <param name="robot_description"
         command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>

  <!-- ── TurtleBot3 bringup (skip if already running) ────── -->
  <include file="$(find turtlebot3_bringup)/launch/turtlebot3_robot.launch"/>

  <!-- ── Static map server ────────────────────────────────── -->
  <node pkg="map_server" type="map_server" name="map_server"
        args="$(arg map_file)"/>

  <!-- ── AMCL Localization ─────────────────────────────────
       Uses RPLIDAR A1M8 /scan + odometry for pose estimation -->
  <node pkg="amcl" type="amcl" name="amcl">
    <param name="min_particles"     value="500"/>
    <param name="max_particles"     value="3000"/>
    <param name="kld_err"           value="0.02"/>
    <param name="kld_z"             value="0.99"/>

    <!-- Motion model (differential drive) -->
    <param name="odom_model_type"   value="diff"/>
    <param name="odom_alpha1"       value="0.1"/>
    <param name="odom_alpha2"       value="0.1"/>
    <param name="odom_alpha3"       value="0.1"/>
    <param name="odom_alpha4"       value="0.1"/>
    <param name="odom_frame_id"     value="odom"/>
    <param name="base_frame_id"     value="base_footprint"/>
    <param name="global_frame_id"   value="map"/>

    <!-- LiDAR sensor model (RPLIDAR A1M8) -->
    <param name="laser_model_type"  value="likelihood_field"/>
    <param name="laser_likelihood_max_dist" value="2.0"/>
    <param name="laser_max_beams"   value="180"/>
    <param name="laser_z_hit"       value="0.5"/>
    <param name="laser_z_rand"      value="0.5"/>
    <param name="laser_sigma_hit"   value="0.2"/>

    <!-- Update rates -->
    <param name="update_min_d"      value="0.10"/>
    <param name="update_min_a"      value="0.10"/>
    <param name="resample_interval" value="1"/>
    <param name="recovery_alpha_slow" value="0.001"/>
    <param name="recovery_alpha_fast" value="0.1"/>

    <!-- Initial pose (near kitchen/starting point) -->
    <param name="initial_pose_x"    value="0.0"/>
    <param name="initial_pose_y"    value="0.0"/>
    <param name="initial_pose_a"    value="0.0"/>
  </node>

  <!-- ── move_base Navigation ──────────────────────────────
       Global: NavFn planner | Local: DWA planner           -->
  <node pkg="move_base" type="move_base" respawn="false"
        name="move_base" output="screen">

    <!-- Planner selection -->
    <param name="base_local_planner"  value="dwa_local_planner/DWAPlannerROS"/>
    <param name="base_global_planner" value="navfn/NavfnROS"/>

    <!-- Costmap configs -->
    <rosparam file="$(find turtlebot3_delivery)/config/costmap_params.yaml"
              command="load" ns="global_costmap"/>
    <rosparam file="$(find turtlebot3_delivery)/config/costmap_params.yaml"
              command="load" ns="local_costmap"/>

    <!-- DWA local planner config -->
    <rosparam file="$(find turtlebot3_delivery)/config/dwa_params.yaml"
              command="load" ns="DWAPlannerROS"/>

    <!-- Global planner tuning -->
    <param name="NavfnROS/allow_unknown"        value="true"/>
    <param name="NavfnROS/default_tolerance"    value="0.10"/>
    <param name="NavfnROS/visualize_potential"  value="false"/>

    <!-- Recovery behaviors -->
    <param name="recovery_behavior_enabled"     value="true"/>
    <param name="clearing_rotation_allowed"     value="true"/>
    <param name="conservative_reset_dist"       value="3.0"/>

    <!-- Planner frequencies -->
    <param name="planner_frequency"             value="1.0"/>
    <param name="controller_frequency"          value="10.0"/>
    <param name="planner_patience"              value="15.0"/>
    <param name="controller_patience"           value="20.0"/>

    <!-- Max retries before reporting failure -->
    <param name="max_planning_retries"          value="3"/>
  </node>

  <!-- ── Robot state publisher ───────────────────────────── -->
  <node pkg="robot_state_publisher" type="robot_state_publisher"
        name="robot_state_publisher">
    <param name="publish_frequency" value="50.0"/>
  </node>

  <!-- ── RViz ─────────────────────────────────────────────── -->
  <group if="$(arg open_rviz)">
    <node pkg="rviz" type="rviz" name="rviz"
          args="-d $(find turtlebot3_navigation)/rviz/turtlebot3_navigation.rviz"/>
  </group>
</launch>
